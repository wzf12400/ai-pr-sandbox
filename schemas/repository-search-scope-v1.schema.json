{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/repository-search-scope-v1.schema.json",
  "title": "Repository search scope v1",
  "description": "An explicit allowlist of GitHub repositories that a read-only repository resolver may search. It is not a service-to-repository routing table.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scope_id",
    "provider",
    "repositories",
    "limits"
  ],
  "properties": {
    "schema_version": {
      "const": "repository-search-scope/v1"
    },
    "scope_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "provider": {
      "const": "github"
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "$comment": "A local semantic validator must reject duplicate repository names and require at least one enabled entry.",
      "items": {
        "$ref": "#/$defs/repository_entry"
      }
    },
    "limits": {
      "$ref": "#/$defs/limits"
    }
  },
  "$defs": {
    "repository_name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,38})/[A-Za-z0-9._-]{1,100}$"
    },
    "repository_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "enabled"
      ],
      "properties": {
        "repository": {
          "$ref": "#/$defs/repository_name"
        },
        "enabled": {
          "type": "boolean"
        },
        "default_branch": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[^\\s~^:?*\\[\\]\\\\]+$"
        },
        "labels": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_queries",
        "max_candidate_repositories",
        "max_hits_per_query"
      ],
      "properties": {
        "max_queries": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        },
        "max_candidate_repositories": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        },
        "max_hits_per_query": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    }
  }
}
